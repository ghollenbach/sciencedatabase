# Firebase Configuration
# Add your Firebase project configuration here
# You can find these values in your Firebase Console -> Project Settings -> General Tab

# Firebase API Key
VITE_FIREBASE_API_KEY=The real API Key

# Firebase Auth Domain (your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=science-inventory-1bea5.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=science-inventory-1bea5


# Firebase Storage Bucket (your-project-id.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET=science-inventory-1bea5.firebasestorage.app

# Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=1007462763984

# Firebase App ID
VITE_FIREBASE_APP_ID=1:1007462763984:web:dd26a20bfbc6eea112bdd5

# Development Configuration
NODE_ENV=development

# Optional: Enable Firebase Auth debug mode (remove in production)
# VITE_FIREBASE_AUTH_DEBUG=true

# Note: 
# 1. To enable Google Authentication, you must configure it in Firebase Console:
#    - Go to Firebase Console -> Authentication -> Sign-in method
#    - Enable Google as a sign-in provider
#    - Add your domain to authorized domains
#
# 2. For production deployment, update these values with your production Firebase config
#
# 3. Never commit sensitive API keys to version control in real projects
#    These values are currently using the existing fallback values from firebase.js